<%- include('partials/header', { title: 'Accueil - Confort Plus' ,
    description: 'Réservez vos voyages pas chers avec Confort Plus' }) %>

        <!-- ===== SECTION HERO AVEC VIDÉO ===== -->
        <section class="hero-video">
            <video class="hero-video__background" autoplay muted loop playsinline>
                <source src="/video/hero.mp4" type="video/mp4">
                <!-- Fallback image si la vidéo ne charge pas -->
                <img src="/images/hero-fallback.jpg" alt="Voyage">
            </video>
            <div class="hero-video__overlay"></div>
            <div class="hero-video__content">
                <h1>Bienvenue sur Confort Plus</h1>
                <p class="hero-slogan">Le confort pas cher, pour des moments inoubliables</p>
                <a href="/reservation" class="btn btn-primary" aria-label="Réserver maintenant">
                    Réserver maintenant
                </a>
            </div>
        </section>

    <!-- ===== SECTION DESTINATIONS ===== -->
    <section id="lieux" class="destinations">
        <div class="section-header">
            <h2>Nos destinations populaires</h2>
            <p class="section-subtitle">Découvrez nos meilleures offres pour des voyages inoubliables</p>
        </div>

        <div class="card-container">
            <!-- Paris -->
            <article class="card">
                <div class="card-image">
                    <img src="/images/tour eifel.jpg" alt="Tour Eiffel à Paris" loading="lazy">
                    <span class="card-badge">À partir de 299€</span>
                </div>
                <div class="card-content">
                    <h3>Paris</h3>
                    <p class="card-description">Pour un voyage en amoureux, vivez des moments magiques dans la ville
                        lumière.</p>
                    <div class="card-features">
                        <span class="feature">⭐ 4.8/5</span>
                        <span class="feature">🏨 120 avis</span>
                    </div>
                    <a href="#" class="btn btn-secondary">En savoir plus</a>
                </div>
            </article>

            <!-- Lyon -->
            <article class="card">
                <div class="card-image">
                    <img src="/images/LYON - En images.jpg" alt="Vue panoramique de Lyon" loading="lazy">
                    <span class="card-badge">À partir de 199€</span>
                </div>
                <div class="card-content">
                    <h3>Lyon</h3>
                    <p class="card-description">Capitale de la gastronomie, Lyon vous séduira par son patrimoine unique.
                    </p>
                    <div class="card-features">
                        <span class="feature">⭐ 4.6/5</span>
                        <span class="feature">🏨 95 avis</span>
                    </div>
                    <a href="#" class="btn btn-secondary">En savoir plus</a>
                </div>
            </article>

            <!-- Marseille -->
            <article class="card">
                <div class="card-image">
                    <img src="/images/Vieux-Port de Marseille, France.jpg" alt="Vieux-Port de Marseille" loading="lazy">
                    <span class="card-badge">À partir de 249€</span>
                </div>
                <div class="card-content">
                    <h3>Marseille</h3>
                    <p class="card-description">Entre mer et collines, découvrez la cité phocéenne et ses calanques.</p>
                    <div class="card-features">
                        <span class="feature">⭐ 4.7/5</span>
                        <span class="feature">🏨 156 avis</span>
                    </div>
                    <a href="#" class="btn btn-secondary">En savoir plus</a>
                </div>
            </article>

            <!-- Bordeaux -->
            <article class="card">
                <div class="card-image">
                    <img src="/images/Place de la bourse.jpg" alt="Place de la Bourse à Bordeaux" loading="lazy">
                    <span class="card-badge">À partir de 279€</span>
                </div>
                <div class="card-content">
                    <h3>Bordeaux</h3>
                    <p class="card-description">Capitale du vin, Bordeaux vous invite à découvrir son architecture
                        majestueuse.</p>
                    <div class="card-features">
                        <span class="feature">⭐ 4.9/5</span>
                        <span class="feature">🏨 203 avis</span>
                    </div>
                    <a href="#" class="btn btn-secondary">En savoir plus</a>
                </div>
            </article>
        </div>
    </section>

        <!-- ===== SECTION SERVICES ===== -->
        <section class="services">
            <div class="section-header">
                <h2>Nos services</h2>
                <p class="section-subtitle">Des prestations sur mesure pour tous vos besoins</p>
            </div>
        
            <div class="services-container">
                <!-- Service Tourisme -->
                <article class="service-card">
                    <div class="service-icon">✈️</div>
                    <h3>Tourisme & Découverte</h3>
                    <p class="service-description">
                        Découvrez les plus beaux sites touristiques avec nos guides expérimentés.
                        Visites culturelles, circuits historiques et aventures nature.
                    </p>
                    <div class="service-features">
                        <span>📍 Visites guidées</span>
                        <span>🗺️ Circuits personnalisés</span>
                        <span>📸 Photos souvenirs</span>
                    </div>
                    <a href="/tourisme" class="btn btn-secondary">En savoir plus</a>
                </article>
        
                <!-- Service Événementiel -->
                <article class="service-card">
                    <div class="service-icon">🎉</div>
                    <h3>Événementiel & Réceptions</h3>
                    <p class="service-description">
                        Organisation de mariages, anniversaires, séminaires et soirées privées.
                        Un service clé en main pour des moments inoubliables.
                    </p>
                    <div class="service-features">
                        <span>💍 Mariages</span>
                        <span>🎂 Anniversaires</span>
                        <span>💼 Séminaires</span>
                    </div>
                    <a href="/evenementiel" class="btn btn-secondary">En savoir plus</a>
                </article>
        
                <!-- Service Premium (optionnel) -->
                <article class="service-card">
                    <div class="service-icon">⭐</div>
                    <h3>Service Premium</h3>
                    <p class="service-description">
                        Pour ceux qui veulent le meilleur : accès VIP, conciergerie 24/7,
                        expériences exclusives et hébergements de luxe.
                    </p>
                    <div class="service-features">
                        <span>👑 Accès VIP</span>
                        <span>🕐 Conciergerie 24/7</span>
                        <span>🏨 Hébergements luxe</span>
                    </div>
                    <a href="/premium" class="btn btn-secondary">En savoir plus</a>
                </article>
            </div>
        </section>

    <%- include('partials/footer') %>