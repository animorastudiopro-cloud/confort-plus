<%- include('partials/header', { title: 'Contact - Confort Plus', description: 'Contactez-nous pour toute question' }) %>

<section class="contact">
    <div class="contact-container">
        <h2>Contactez-nous</h2>
        <p>Une question ? Notre équipe est là pour vous répondre</p>
        <div class="contact-grid">
            <div class="contact-info">
                <div class="contact-item">
                    <span class="contact-icon">📍</span>
                    <div>
                        <h3>Adresse</h3>
                        <p>123 Rue du Voyage<br>75001 Paris, France</p>
                    </div>
                </div>
                <div class="contact-item">
                    <span class="contact-icon">📞</span>
                    <div>
                        <h3>Téléphone</h3>
                        <p><a href="tel:+33123456789">+33 1 23 45 67 89</a></p>
                    </div>
                </div>
                <div class="contact-item">
                    <span class="contact-icon">✉️</span>
                    <div>
                        <h3>Email</h3>
                        <p><a href="mailto:contact@confortplus.com">contact@confortplus.com</a></p>
                    </div>
                </div>
            </div>
            <form class="contact-form" action="/envoyer-contact" method="post">
                <div class="form-group">
                    <label for="nom">Nom</label>
                    <input type="text" id="nom" name="nom" required>
                </div>
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" required>
                </div>
                <div class="form-group">
                    <label for="message">Message</label>
                    <textarea id="message" name="message" rows="5" required></textarea>
                </div>
                <button type="submit" class="btn btn-primary">Envoyer</button>
            </form>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
