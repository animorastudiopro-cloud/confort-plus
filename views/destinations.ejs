<%- include('partials/header', { title: 'Destinations - Confort Plus', description: 'Découvrez nos destinations de rêve' }) %>

<section class="destinations">
    <div class="section-header">
        <h2>Nos destinations</h2>
        <p class="section-subtitle">Choisissez votre prochaine aventure</p>
    </div>

    <div class="card-container">
        <!-- Paris -->
        <article class="card">
            <div class="card-image">
                <img src="/images/tour eifel.jpg" alt="Tour Eiffel à Paris" loading="lazy">
                <span class="card-badge">À partir de 299€</span>
            </div>
            <div class="card-content">
                <h3>Paris</h3>
                <p class="card-description">Pour un voyage en amoureux, vivez des moments magiques dans la ville lumière.</p>
                <div class="card-features">
                    <span class="feature">⭐ 4.8/5</span>
                    <span class="feature">🏨 120 avis</span>
                </div>
                <a href="/reservation" class="btn btn-secondary">Réserver</a>
            </div>
        </article>

        <!-- Lyon -->
        <article class="card">
            <div class="card-image">
                <img src="/images/LYON - En images.jpg" alt="Vue panoramique de Lyon" loading="lazy">
                <span class="card-badge">À partir de 199€</span>
            </div>
            <div class="card-content">
                <h3>Lyon</h3>
                <p class="card-description">Capitale de la gastronomie, Lyon vous séduira par son patrimoine unique.</p>
                <div class="card-features">
                    <span class="feature">⭐ 4.6/5</span>
                    <span class="feature">🏨 95 avis</span>
                </div>
                <a href="/reservation" class="btn btn-secondary">Réserver</a>
            </div>
        </article>

        <!-- Marseille -->
        <article class="card">
            <div class="card-image">
                <img src="/images/Vieux-Port de Marseille, France.jpg" alt="Vieux-Port de Marseille" loading="lazy">
                <span class="card-badge">À partir de 249€</span>
            </div>
            <div class="card-content">
                <h3>Marseille</h3>
                <p class="card-description">Entre mer et collines, découvrez la cité phocéenne et ses calanques.</p>
                <div class="card-features">
                    <span class="feature">⭐ 4.7/5</span>
                    <span class="feature">🏨 156 avis</span>
                </div>
                <a href="/reservation" class="btn btn-secondary">Réserver</a>
            </div>
        </article>

        <!-- Bordeaux -->
        <article class="card">
            <div class="card-image">
                <img src="/images/Place de la bourse.jpg" alt="Place de la Bourse à Bordeaux" loading="lazy">
                <span class="card-badge">À partir de 279€</span>
            </div>
            <div class="card-content">
                <h3>Bordeaux</h3>
                <p class="card-description">Capitale du vin, Bordeaux vous invite à découvrir son architecture majestueuse.</p>
                <div class="card-features">
                    <span class="feature">⭐ 4.9/5</span>
                    <span class="feature">🏨 203 avis</span>
                </div>
                <a href="/reservation" class="btn btn-secondary">Réserver</a>
            </div>
        </article>
    </div>
</section>

<%- include('partials/footer') %>
