<%- include('partials/header', { title: 'Réservation - Confort Plus', description: 'Réservez votre voyage en quelques clics' }) %>

<section class="reservation">
    <div class="reservation-container">
        <h2>Prêt à partir ?</h2>
        <p>Réservez votre séjour en quelques clics</p>
        <form class="reservation-form" action="/envoyer-reservation" method="post">
            <div class="form-group">
                <label for="destination">Destination</label>
                <select id="destination" name="destination" required>
                    <option value="">Choisissez une destination</option>
                    <option value="Paris">Paris</option>
                    <option value="Lyon">Lyon</option>
                    <option value="Marseille">Marseille</option>
                    <option value="Bordeaux">Bordeaux</option>
                </select>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label for="date-depart">Date de départ</label>
                    <input type="date" id="date-depart" name="dateDepart" required>
                </div>
                <div class="form-group">
                    <label for="date-retour">Date de retour</label>
                    <input type="date" id="date-retour" name="dateRetour" required>
                </div>
            </div>
            <div class="form-group">
                <label for="voyageurs">Nombre de voyageurs</label>
                <input type="number" id="voyageurs" name="voyageurs" min="1" max="10" value="2" required>
            </div>
            <button type="submit" class="btn btn-primary btn-large">Rechercher</button>
        </form>
    </div>
</section>

<%- include('partials/footer') %>
